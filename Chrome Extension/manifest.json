// FILE 1: manifest.json
{
  "manifest_version": 3,
  "name": "Universal AI Chat Auto-Focus",
  "version": "1.0",
  "description": "Auto-focus input on Ctrl+V for all AI chat platforms",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*", 
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok/*",
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
